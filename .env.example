# === Database ===
DATABASE_URL=postgresql://nuhoot:changeme@localhost:5432/nuhoot

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === AI (GLM 5.2 via umans.ai) ===
UMANS_API_KEY=sk-your-key-here
AI_MODEL=umans-glm-5.2
AI_BASE_URL=https://api.code.umans.ai/v1

# === WhatsApp Cloud API ===
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token

# === Google Maps Scraper ===
GOSOM_BINARY_PATH=/usr/local/bin/gosom
SCRAPER_MAX_RESULTS=200
SCRAPER_DELAY_SECONDS=2

# === App ===
APP_ENV=development
APP_SECRET_KEY=change-this-in-production
APP_TIMEZONE=Asia/Riyadh
APP_LANGUAGE=ar

# === GitHub ===
GITHUB_TOKEN=your-github-token
